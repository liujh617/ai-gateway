{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-ai-gateway.local/schema/config.schema.json",
  "title": "open-ai-gateway config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "addr": {
      "type": "string",
      "description": "HTTP listen address in host:port format."
    },
    "api_key": {
      "type": "string",
      "description": "Gateway API key for client Bearer auth."
    },
    "api_keys": {
      "type": "array",
      "description": "Gateway API keys for client Bearer auth.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "api_clients": {
      "type": "array",
      "description": "Named gateway API keys for client Bearer auth and observability labels.",
      "items": {
        "$ref": "#/$defs/api_client"
      }
    },
    "request_timeout_seconds": {
      "type": "integer",
      "minimum": 0
    },
    "stream_timeout_seconds": {
      "type": "integer",
      "minimum": 0
    },
    "read_header_timeout_seconds": {
      "type": "integer",
      "minimum": 0
    },
    "read_timeout_seconds": {
      "type": "integer",
      "minimum": 0
    },
    "write_timeout_seconds": {
      "type": "integer",
      "minimum": 0
    },
    "idle_timeout_seconds": {
      "type": "integer",
      "minimum": 0
    },
    "shutdown_timeout_seconds": {
      "type": "integer",
      "minimum": 0
    },
    "max_request_body_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "log": {
      "$ref": "#/$defs/log"
    },
    "api_client": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "api_key": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["name", "api_key"]
    },
    "rate_limit": {
      "$ref": "#/$defs/rate_limit"
    },
    "provider_health": {
      "$ref": "#/$defs/provider_health"
    },
    "providers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/provider"
      }
    },
    "models": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/model"
      }
    }
  },
  "required": [
    "providers",
    "models"
  ],
  "$defs": {
    "log": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": {
          "type": "string",
          "enum": ["text", "json"]
        },
        "level": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"]
        }
      }
    },
    "rate_limit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requests_per_minute": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "provider_health": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "failure_threshold": {
          "type": "integer",
          "minimum": 0
        },
        "cooldown_seconds": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["fake", "openai-compatible"]
        },
        "base_url": {
          "type": "string",
          "format": "uri"
        },
        "api_key": {
          "type": "string"
        },
        "api_key_env": {
          "type": "string"
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": ["type"]
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string"
        },
        "upstream_model": {
          "type": "string"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["chat", "embeddings"]
          },
          "uniqueItems": true
        },
        "pricing": {
          "$ref": "#/$defs/pricing"
        },
        "fallbacks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/model_fallback"
          }
        }
      },
      "required": ["provider"]
    },
    "model_fallback": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string"
        },
        "upstream_model": {
          "type": "string"
        },
        "pricing": {
          "$ref": "#/$defs/pricing"
        }
      },
      "required": ["provider"]
    },
    "pricing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prompt_usd_per_1m_tokens": {
          "type": "number",
          "minimum": 0
        },
        "completion_usd_per_1m_tokens": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
